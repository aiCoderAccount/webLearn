<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " - WebLearn" : "WebLearn - Computer Networks")</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">
                <i class="bi bi-diagram-3-fill text-primary"></i> WebLearn
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Course">Courses</a></li>
                </ul>
                <ul class="navbar-nav">
                    @if (Context.Session.GetInt32("InstructorId") != null)
                    {
                        <li class="nav-item"><a class="nav-link" href="/Instructor/Dashboard"><i class="bi bi-person-circle"></i> @Context.Session.GetString("InstructorName")</a></li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" href="/Auth/Login"><i class="bi bi-box-arrow-in-right"></i> Instructor Login</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    @if (ViewData["ShowBanner"] as bool? == true)
    {
        <div class="hero-banner py-5 text-white text-center">
            <div class="container">
                <h1 class="display-4 fw-bold"><i class="bi bi-diagram-3"></i> Computer Networks Learning</h1>
                <p class="lead">Master the fundamentals of networking — from OSI to TCP/IP, DNS, HTTP and beyond.</p>
                <a href="/Course" class="btn btn-primary btn-lg mt-2">Browse Courses</a>
            </div>
        </div>
    }

    <main class="container py-4">
        @await Html.PartialAsync("_Notification")
        @RenderBody()
    </main>

    <footer class="bg-dark text-secondary py-4">
        <div class="container text-center">
            <p class="mb-0">&copy; @DateTime.Now.Year WebLearn — Computer Networks Education Platform</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
