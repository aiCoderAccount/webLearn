<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " - Instructor" : "Instructor Dashboard") - WebLearn</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css">
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-primary">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" href="/Instructor/Dashboard">
                <i class="bi bi-diagram-3-fill"></i> WebLearn Instructor
            </a>
            <div class="d-flex align-items-center gap-3">
                <span class="text-white"><i class="bi bi-person-circle"></i> @Context.Session.GetString("InstructorName")</span>
                <a href="/" class="btn btn-sm btn-outline-light"><i class="bi bi-house"></i> Public Site</a>
                <form method="post" action="/Auth/Logout" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-danger"><i class="bi bi-box-arrow-right"></i> Logout</button>
                </form>
            </div>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">
            <nav class="col-md-2 sidebar py-3 bg-white border-end min-vh-100">
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActiveNav"]?.ToString() == "dashboard" ? "active fw-bold" : "")" href="/Instructor/Dashboard">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActiveNav"]?.ToString() == "courses" ? "active fw-bold" : "")" href="/Instructor/Courses">
                            <i class="bi bi-book"></i> My Courses
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActiveNav"]?.ToString() == "lessons" ? "active fw-bold" : "")" href="/Instructor/Lessons">
                            <i class="bi bi-file-earmark-text"></i> My Lessons
                        </a>
                    </li>
                </ul>
            </nav>

            <main class="col-md-10 py-4 px-4">
                @await Html.PartialAsync("_Notification")
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
