@model IEnumerable<WebLearn.Models.Course>
@{
    ViewData["Title"] = "Courses";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-collection"></i> All Courses</h1>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No courses are currently available.</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 g-4">
        @foreach (var course in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title"><i class="bi bi-book text-primary"></i> @course.Title</h5>
                        <p class="card-text text-muted">@course.Description</p>
                        <p class="card-text"><small class="text-muted"><i class="bi bi-person"></i> @course.InstructorName</small></p>
                    </div>
                    <div class="card-footer bg-transparent">
                        <a href="/Course/Detail/@course.Id" class="btn btn-primary btn-sm">
                            <i class="bi bi-arrow-right-circle"></i> View Course
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
