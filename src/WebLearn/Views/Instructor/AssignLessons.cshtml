@model WebLearn.Models.ViewModels.AssignLessonViewModel
@{
    ViewData["Title"] = "Assign Lessons";
    ViewData["ActiveNav"] = "courses";
    Layout = "_InstructorLayout";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/Instructor/Courses">Courses</a></li>
        <li class="breadcrumb-item"><a href="/Instructor/Units?courseId=@Model.Course.Id">@Model.Course.Title</a></li>
        <li class="breadcrumb-item active">Assign Lessons</li>
    </ol>
</nav>

<h1 class="h3 mb-1"><i class="bi bi-list-check"></i> Assign Lessons</h1>
<p class="text-muted mb-4">Unit: <strong>@Model.Unit.Title</strong></p>

<form method="post" asp-action="AssignLessons">
    @Html.AntiForgeryToken()
    <input type="hidden" name="unitId" value="@Model.Unit.Id">

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            @if (!Model.AllLessons.Any())
            {
                <div class="alert alert-info">You have no lessons yet. <a href="/Instructor/CreateLesson">Create a lesson first.</a></div>
            }
            else
            {
                <div class="list-group">
                    @foreach (var item in Model.AllLessons)
                    {
                        <label class="list-group-item d-flex align-items-center gap-3">
                            <input type="checkbox" class="form-check-input" name="lessonIds" value="@item.LessonId"
                                   @(item.IsAssigned ? "checked" : "")>
                            <span><i class="bi bi-file-earmark-text text-primary"></i> @item.Title</span>
                            @if (item.IsAssigned)
                            {
                                <span class="badge bg-success ms-auto">Assigned</span>
                            }
                        </label>
                    }
                </div>
            }
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Save Assignments</button>
        <a href="/Instructor/Units?courseId=@Model.Course.Id" class="btn btn-secondary">Cancel</a>
    </div>
</form>
