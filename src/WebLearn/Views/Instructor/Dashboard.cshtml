@{
    ViewData["Title"] = "Dashboard";
    ViewData["ActiveNav"] = "dashboard";
    Layout = "_InstructorLayout";
}

<h1 class="h3 mb-4"><i class="bi bi-speedometer2"></i> Dashboard</h1>
<p class="text-muted">Welcome back, <strong>@ViewData["InstructorName"]</strong>!</p>

<div class="row g-4 mb-5">
    <div class="col-md-3">
        <div class="card text-white bg-primary">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h2 class="mb-0">@ViewData["CourseCount"]</h2>
                        <p class="mb-0">Courses</p>
                    </div>
                    <i class="bi bi-book display-5 opacity-50"></i>
                </div>
            </div>
            <div class="card-footer"><a href="/Instructor/Courses" class="text-white text-decoration-none small">Manage Courses →</a></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h2 class="mb-0">@ViewData["LessonCount"]</h2>
                        <p class="mb-0">Lessons</p>
                    </div>
                    <i class="bi bi-file-earmark-text display-5 opacity-50"></i>
                </div>
            </div>
            <div class="card-footer"><a href="/Instructor/Lessons" class="text-white text-decoration-none small">Manage Lessons →</a></div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body text-center">
                <i class="bi bi-plus-circle display-5 text-primary"></i>
                <h5 class="mt-3">New Course</h5>
                <a href="/Instructor/CreateCourse" class="btn btn-primary btn-sm mt-2">Create Course</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body text-center">
                <i class="bi bi-file-earmark-plus display-5 text-success"></i>
                <h5 class="mt-3">New Lesson</h5>
                <a href="/Instructor/CreateLesson" class="btn btn-success btn-sm mt-2">Create Lesson</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body text-center">
                <i class="bi bi-eye display-5 text-info"></i>
                <h5 class="mt-3">Public Site</h5>
                <a href="/" class="btn btn-info btn-sm mt-2">View Site</a>
            </div>
        </div>
    </div>
</div>
