@model IEnumerable<WebLearn.Models.Lesson>
@{
    ViewData["Title"] = "My Lessons";
    ViewData["ActiveNav"] = "lessons";
    Layout = "_InstructorLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3"><i class="bi bi-file-earmark-text"></i> My Lessons</h1>
    <a href="/Instructor/CreateLesson" class="btn btn-success"><i class="bi bi-plus-circle"></i> New Lesson</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">You have no lessons yet. <a href="/Instructor/CreateLesson">Create your first lesson.</a></div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr><th>Title</th><th>Created</th><th>Actions</th></tr>
            </thead>
            <tbody>
                @foreach (var lesson in Model)
                {
                    <tr>
                        <td><strong>@lesson.Title</strong></td>
                        <td><small>@lesson.CreatedAt.ToString("yyyy-MM-dd")</small></td>
                        <td>
                            <a href="/Instructor/EditLesson/@lesson.Id" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i> Edit</a>
                            <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#delLesson-@lesson.Id">
                                <i class="bi bi-trash"></i>
                            </button>
                            <div class="modal fade" id="delLesson-@lesson.Id" tabindex="-1">
                                <div class="modal-dialog">
                                    <div class="modal-content">
                                        <div class="modal-header"><h5>Confirm Delete</h5></div>
                                        <div class="modal-body">Delete lesson <strong>@lesson.Title</strong>?</div>
                                        <div class="modal-footer">
                                            <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                            <form method="post" action="/Instructor/DeleteLesson" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@lesson.Id">
                                                <button type="submit" class="btn btn-danger">Delete</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
