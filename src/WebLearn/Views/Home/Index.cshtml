@model IEnumerable<WebLearn.Models.Course>
@{
    ViewData["Title"] = "Home";
    ViewData["ShowBanner"] = true;
}

<section class="mb-5">
    <h2 class="mb-4"><i class="bi bi-stars"></i> Featured Courses</h2>
    @if (!Model.Any())
    {
        <div class="alert alert-info">No courses available yet. Check back soon!</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var course in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title"><i class="bi bi-book text-primary"></i> @course.Title</h5>
                            <p class="card-text text-muted">@course.Description</p>
                            <p class="card-text"><small class="text-muted">By @course.InstructorName</small></p>
                        </div>
                        <div class="card-footer bg-transparent">
                            <a href="/Course/Detail/@course.Id" class="btn btn-primary btn-sm">
                                <i class="bi bi-arrow-right-circle"></i> Start Learning
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</section>

<section class="py-4 bg-light rounded">
    <div class="container">
        <div class="row text-center">
            <div class="col-md-4">
                <i class="bi bi-layers display-6 text-primary"></i>
                <h5 class="mt-2">Structured Learning</h5>
                <p class="text-muted">Courses organized into units and lessons for progressive learning.</p>
            </div>
            <div class="col-md-4">
                <i class="bi bi-question-circle display-6 text-success"></i>
                <h5 class="mt-2">Interactive Quizzes</h5>
                <p class="text-muted">Test your knowledge with built-in quizzes and exercises.</p>
            </div>
            <div class="col-md-4">
                <i class="bi bi-code-slash display-6 text-warning"></i>
                <h5 class="mt-2">Practical Examples</h5>
                <p class="text-muted">Code blocks, diagrams, and hands-on exercises throughout.</p>
            </div>
        </div>
    </div>
</section>
